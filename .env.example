# Public metrics endpoint exposed by the fast-auth-metrics-dashboard.
# Returns 4 KPIs (total accounts, active 24h, sign events 7d, uptime 24h)
# and is read at build/ISR time by app/page.tsx via lib/metrics.ts.
#
# - Dev: defaults to http://localhost:3000/api/public/metrics if unset, so
#   running the dashboard alongside on :3000 just works. Override here if
#   you run the dashboard on a different port.
# - Production: REQUIRED. If unset in NODE_ENV=production, lib/metrics.ts
#   returns null and the Stats section renders "Live data unavailable".
FASTAUTH_METRICS_URL=
